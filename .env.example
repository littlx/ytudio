# ===== 必填（仅字幕翻译模式需要）=====
# 复制为 .env 并填入你的 DeepSeek API Key
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=在此填入你的key

# ===== 可选 =====

# DeepSeek 模型：deepseek-v4-flash 原生 1M tokens 上下文，可整篇翻译超长字幕
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 翻译：默认整篇一次性翻译（上下文最完整）。仅当字幕字符数超过
# WHOLE_TRANSLATE_LIMIT 时才退回分批，每批 TRANSLATE_CHUNK_SIZE 字符。
# WHOLE_TRANSLATE_LIMIT=800000
# TRANSLATE_CHUNK_SIZE=4000

# yt-dlp cookies：绕过 YouTube 机器人检测（提示 "Sign in to confirm you're not a bot" 时开启）
# 推荐方式：在网页「🍪 登录 Cookies」面板上传 cookies.txt（无需此配置，服务器无浏览器也适用）
# 服务器有浏览器时，可填浏览器名自动读取：chrome / safari / firefox / edge / brave
# COOKIES_FROM_BROWSER=chrome
# 或用 cookies 文件绝对路径
# COOKIES_FILE=

# yt-dlp 远程组件：解决 YouTube n-challenge（现代 YouTube 必需，默认已开启）
# 需要系统装有 deno 或 node。留空禁用。
# REMOTE_COMPONENTS=ejs:github

# edge-tts 中文语音
# TTS_VOICE=zh-CN-XiaoxiaoNeural

# 服务端口
# PORT=8200
